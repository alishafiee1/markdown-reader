# Copy to .env or export before npm start

PORT=4002
HOST=0.0.0.0
# NODE_ENV=production

# Behind nginx/HTTPS in production
# COOKIE_SECURE=true
# TRUST_PROXY=1

# Optional — default: data/articles.db
# MARKDOWN_READER_DB=./data/articles.db

# Seed admin user "admino" password (change in production)
# ADMIN_SEED_PASSWORD=your-secure-password

# Auth validation — default keeps the current local-friendly minimum
# AUTH_MIN_PASSWORD_LENGTH=4

# Run integration tests: MD_READER_RUN_TESTS=1 npm test
